{
    "compilerOptions": {
        "baseUrl": ".",
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "target": "es2019",
        "allowJs": true,
        "noImplicitAny": true,
        "moduleResolution": "bundler",
        "importHelpers": true,
        "isolatedModules": true,
        "strictNullChecks": true,
        "verbatimModuleSyntax": true,
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "lib": ["DOM", "es2019"]
    },
    "include": ["**/*.ts"],
    "exclude": ["**/*.test.ts"]
}
